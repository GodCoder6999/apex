# Route every /api/* request through the front controller.
RewriteEngine On
RewriteBase /api/

# Don't rewrite real files/dirs (none here besides the PHP, but safe).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L]

# Never serve the credentials or sample over HTTP.
<FilesMatch "db_credentials(\.sample)?\.php$">
  Require all denied
</FilesMatch>

# Reasonable upload size for product image data-URLs.
php_value post_max_size 12M
php_value upload_max_filesize 12M
