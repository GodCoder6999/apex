{
  "expo": {
    "name": "Apex Owner",
    "slug": "apex-owner-mobile",
    "owner": "anirbanherbalcure",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "apexowner",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B1220",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.apex.owner"
    },
    "android": {
      "package": "in.apex.owner",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Apex uses the camera to scan product barcodes and serials."
        }
      ]
    ],
    "extra": {
      "apiBase": "",
      "eas": {
        "projectId": "35331770-87d0-4ed4-90ff-6fdbe3334c19"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/35331770-87d0-4ed4-90ff-6fdbe3334c19"
    }
  }
}
